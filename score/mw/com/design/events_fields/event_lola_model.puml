@startuml event_lola_model
title "Event Lola Model"

' Abstract classes and interfaces
abstract SkeletonEventBindingBase {
  {abstract} +PrepareOffer(): void
  {abstract} +PrepareStopOffer(): void
  {abstract} +GetMaxSize(): size_t
}

abstract class SkeletonEventBinding<SampleType> {
  {abstract} +Send(SampleType const&): void
  {abstract} +Send(SampleAllocateePtr<SampleType>): void
  {abstract} +Allocate(): SampleAllocateePtr<SampleType>
  +GetMaxSize(): size_t
}

abstract class ProxyEventBindingBase {
  {abstract} +Subscribe(size_t maxSampleCount): void
  {abstract} +Unsubscribe(): void
  {abstract} +GetSubscriptionState(): SubscriptionState
  {abstract} +SetReceiveHandler(EventReceiveHandler): void
  {abstract} +UnsetReceiveHandler(): void
  {abstract} +GetNumNewSamplesAvailable(): Result<size_t>
}

abstract class ProxyEventBinding<SampleType> {
  {abstract} +GetNewSamples(score::cpp::callback<void(SamplePtr<SampleType>)>&&, TrackerGuardFactory): Result<size_t>
  {static} # MakeSamplePtr(BindingSamplePtr&&, SampleReferenceGuard): SamplePtr<SampleType>
}

abstract class SkeletonBinding {
  -events_: SkeletonEvents&
  +SkeletonBinding(SkeletonEvents&): void
  {abstract} +PrepareStopOffer(): void
  {abstract} +PrepareOffer(): Result<void>
}

' Concrete classes
class lola::SkeletonEvent<SampleType> {
  -event_data_storage: EventDataStorage<SampleType>*
  -skeleton_event_common_: SkeletonEventCommon<SampleType>
  +SkeletonEvent(parent: Skeleton&, element_fq_id: const ElementFqId, max_number_of_slots: const std::size_t, enforce_max_samples: const bool)
  +Send(SampleType const&): void
  +Send(SampleAllocateePtr<SampleType>): void
  +Allocate(): SampleAllocateePtr<SampleType>
  +PrepareOffer(): void
  +PrepareStopOffer(): void
}

class lola::SkeletonEventCommon<SampleType> {
  -provider_control_local_view_qm_: std::optional<ProviderEventDataControlLocalView<>>
  -provider_control_local_view_asil_b_: std::optional<ProviderEventDataControlLocalView<>>
  -consumer_control_local_view_qm_: std::optional<ConsumerEventDataControlLocalView<>>
  -consumer_control_local_view_asil_: std::optional<ConsumerEventDataControlLocalView<>>
  -event_data_control_composite_: std::optional<EventDataControlComposite<>>
  +PrepareOfferCommon(event_control_qm: EventControl&, event_control_asil_b: EventControl*): void
  +PrepareStopOfferCommon(): void
  +AllocateSlot(): Result<SlotIndexType>
  +Send(sample: SampleAllocateePtr<SampleType>&): Result<void>
  +GetEventDataControlComposite(): EventDataControlComposite<>&
  +GetConsumerEventDataControlLocalView(quality_type: QualityType): ConsumerEventDataControlLocalView<>&
  ..
  <u>Notes:</u>
  Created/destroyed in PrepareOfferCommon/PrepareStopOfferCommon.
  Avoids OffsetPtr overhead by holding raw-pointer-based local views
  into shared-memory EventDataControl after mapping it once at offer time.
}

class lola::ProxyEvent<SampleType> {
  -parent: Proxy&
  -subscription_state_machine: std::shared_ptr<SubscriptionStateMachine>
  +ProxyEvent(ProxyBase& parent, ElementFqId)
  +Subscribe(size_t maxSampleCount): void
  +GetSubscriptionState(): SubscriptionState
  +Unsubscribe(): void
  +SetReceiveHandler(score::cpp::callback<void(void)>): void
  +UnsetReceiveHandler(): void
  +GetNewSamples(score::cpp::callback<void(SamplePtr<SampleType>)>&&, TrackerGuardFactory): Result<size_t>
  +GetNumNewSamplesAvailable(): Result<size_t>
  ..
  <u>Notes:</u>
  Dispatches all calls to functions in ProxyEventBindingBase interface to\nProxyEventCommon.
}

class lola::Skeleton {
  -data: SkeletonDataStorage*
  -control_qm_: SkeletonDataControl*
  -control_asil_b_: SkeletonDataControl*
  +Skeleton(const InstanceIdentifier&, SkeletonEvents&)
  +PrepareOffer(): Result<void>
  +PrepareStopOffer(): Result<void>
  +Register(ElementFqId, size_t numberOfSlots): std::pair<EventDataStorage*, EventDataControlComposite<>>
  +GetInstanceQualityType() const: QualityType
}

class lola::ProxyEventCommon {
  -element_fq_id_: ElementFqId
  -parent_: lola::Proxy&
  -subscription_event_state_machine_: std::shared_ptr<SubscriptionStateMachine>
  -event_control_local_: ConsumerEventControlLocalView&
  __
  +ProxyEventCommon(lola::Proxy& parent, ElementFqId)
  +Subscribe(size_t max_sample_count): void
  +Unsubscribe(): void
  +GetSubscriptionState(): SubscriptionState
  +SetReceiveHandler(EventReceiveHandler handler): void
  +UnsetReceiveHandler(EventReceiveHandler handler): void
  +GetEventSourcePid(): pid_t
  +GetElementFQId(): ElementFqId
  +GetNumNewSamplesAvailable(): Result<std::size_t>
  +GetNewSamplesSlotIndices(size_t max_count): pair<SlotIndexVector::const_reverse_iterator, SlotIndexVector::const_reverse_iterator>
  +GetEventControl(): ConsumerEventControlLocalView&
  ..
  <u>Notes:</u>
  lola::ProxyEventCommon is not moveable or copyable.
  event_control_local_ is obtained from ProxyServiceDataControlLocalView at
  construction time. SlotCollector is instantiated by the SubscriptionStateMachine
  when it enters the Subscribed state.
  All subscription operations are implemented in the separate class
  SubscriptionStateMachine and the associated states.
}

class lola::SubscriptionStateMachine {
  ..
  <u>Notes:</u>
  State machine that manages subscriptions to a ProxyEvent.\nDetails about the state machine can be found in\nproxy_event_state_machine.puml and proxy_event_state_machine_model.puml
}

class lola::SlotCollector {
  -event_data_control_local_: ConsumerEventDataControlLocalView<>&
  +SlotCollector(event_data_control_local: ConsumerEventDataControlLocalView<>&, const std::size_t max_slots)
  +GetNumNewSamplesAvailable(): size_t
  +GetNewSamplesSlotIndices(size_t max_count): pair<SlotIndexVector::const_reverse_iterator, SlotIndexVector::const_reverse_iterator>
  ..
  <u>Notes:</u>
  SlotCollector is not copyable.
  Uses ConsumerEventDataControlLocalView to avoid OffsetPtr overhead
  when scanning shared-memory slot state during GetNewSamples().
}

class lola::ShmPathBuilder {
  +ShmPathBuilder(instance_deployment: const LolaServiceInstanceDeployment&, type_deploymenttype_deployment: const LolaServiceTypeDeployment&)
  +GetDataChannelShmName(): score::cpp::optional<std::string>
  +GetControlChannelShmName(const QualityType channel_type): score::cpp::optional<std::string>
}

' Template classes and typedefs
class SampleAllocateePtr<SampleType> {
  -internal: std::variant<score::cpp::blank, lola::SampleAllocateePtr, std::unique_ptr<SampleType>>
  ..
  <u>Notes:</u>
  Variant is used to enable future version were multiple backends are supported

}

class lola::SampleAllocateePtr<SampleType> {
  -managed_object_: SampleType*
  -event_slot_index_: SlotIndexType
  -event_data_control_: std::optional<EventDataControlComposite<>>
  -consumer_event_data_control_local_view_: ConsumerEventDataControlLocalView<>*
  +SampleAllocateePtr()
  +SampleAllocateePtr(std::nullptr_t)
  +SampleAllocateePtr(ptr: pointer, event_data_ctrl: EventDataControlComposite<>&, slot_index: SlotIndexType, consumer_view: ConsumerEventDataControlLocalView<>&)
  +GetReferencedSlot() const: SlotIndexType
  +get() const: SampleType*
  +reset(std::nullptr_t): void
  +swap(other: SampleAllocateePtr&): void
  ..
  <u>Notes:</u>
  consumer_event_data_control_local_view_ is used by IPC-tracing on
  skeleton side to reference/dereference the allocated slot for tracing.
}

class SamplePtr<SampleType> {
  #internal: std::variant<lola::SamplePtr>
  +SampleAllocateePtr(std::nullptr_t)
  +reset(const pointer ptr = SampleType*): void
  +swap(other: SampleAllocateePtr<SampleType>&): void
  +get(): SampleType*
  ..
  <u>Notes:</u>
  Variant is used to enable future\nversion were multiple backends are supported
}

class lola::SamplePtr<SampleType> {
  -managed_object_: SampleType*
  -slot_decrementer_: std::optional<SlotDecrementer>
  +SamplePtr()
  +SamplePtr(std::nullptr_t)
  +SamplePtr(ptr: pointer, consumer_view: ConsumerEventDataControlLocalView<>&, slot_index: SlotIndexType)
  +get() const: pointer
  +swap(): void
  ..
  <u>Notes:</u>
  SlotDecrementer (RAII) holds a reference to ConsumerEventDataControlLocalView
  and calls DereferenceEvent() on destruction, decrementing the slot ref-count.
}

class lola::SlotDecrementer {
  -event_data_control_local_: ConsumerEventDataControlLocalView<>*
  -event_slot_index_: SlotIndexType
  +SlotDecrementer(event_data_control: ConsumerEventDataControlLocalView<>&, slot_index: SlotIndexType)
  +~SlotDecrementer() : calls DereferenceEvent()
}

' Shared memory classes
class "<<SharedMemory>>\n<<typedef>>\nEventDataStorage<SampleType>" as EventDataStorage {
  DynamicArray<SampleType,\nstd::scoped_allocator_adaptor<memory::shared::PolymorphicOffsetPtrAllocator<SampleType>>>
  ..
  <u>Notes:</u>
  Exists once per Event\nOnly writable by Skeleton,\nreadable by all subscribed Proxies independent of ASIL level.
}

class "<<SharedMemory>>\n<<typedef>>\nSkeletonDataStorage<SampleType>" as SkeletonDataStorage {
  std::map<ElementFqId, offset_ptr<void>>
  ..
  <u>Notes:</u>
  The offset_ptr<void> SkeletonDataStorage stored as the value in the map is an offset_ptr<EventDataStorage> which has its type erased.\nThe type is identified later when samples are retrieved, see GetNewSamples for an explanation.
}

' Local view classes (non-shared-memory, live in process heap)
class ProviderEventDataControlLocalView<AtomicIndirectorType> {
  -state_slots_: LocalEventControlSlots (score::cpp::span<ControlSlotType>)
  +ProviderEventDataControlLocalView(event_data_control: EventDataControl&)
  +AllocateNextSlot(): std::optional<SlotIndexType>
  +EventReady(slot_index: SlotIndexType, time_stamp: EventSlotStatus::EventTimeStamp): void
  +Discard(slot_index: SlotIndexType): void
  +operator[](slot_index: SlotIndexType) const: EventSlotStatus
  +RemoveAllocationsForWriting(): void
  ..
  <u>Notes:</u>
  Provider (skeleton) side local view of EventDataControl.\nHolds a raw span into shared-memory state_slots_ (no OffsetPtr on hot path).
}

class ConsumerEventDataControlLocalView<AtomicIndirectorType> {
  -state_slots_: LocalEventControlSlots (score::cpp::span<ControlSlotType>)
  -transaction_log_local_view_: std::optional<TransactionLogLocalView>
  +ConsumerEventDataControlLocalView(event_data_control: EventDataControl&)
  +ReferenceNextEvent(last_search_time: EventSlotStatus::EventTimeStamp, upper_limit: EventSlotStatus::EventTimeStamp): std::optional<SlotIndexType>
  +GetLatestSlot(): std::optional<SlotIndexType>
  +ReferenceSpecificEvent(slot_index: SlotIndexType): void
  +GetNumNewEvents(reference_time: EventSlotStatus::EventTimeStamp) const: std::size_t
  +DereferenceEvent(slot_index: SlotIndexType): void
  +DereferenceEventWithoutTransactionLogging(slot_index: SlotIndexType): void
  +operator[](slot_index: SlotIndexType) const: EventSlotStatus
  ..
  <u>Notes:</u>
  Consumer (proxy/tracing) side local view of EventDataControl.\nHolds a raw span into shared-memory state_slots_ (no OffsetPtr on hot path).
}

class ConsumerEventControlLocalView {
  +data_control: ConsumerEventDataControlLocalView<>
  +subscription_control: std::reference_wrapper<EventSubscriptionControl<>>
  +transaction_log_set: std::reference_wrapper<TransactionLogSet>
  +ConsumerEventControlLocalView(event_control: EventControl&)
  ..
  <u>Notes:</u>
  Aggregated local view of a single EventControl entry from shared memory.
}

class ProxyServiceDataControlLocalView {
  +event_controls_: Map<ElementFqId, ConsumerEventControlLocalView>
  +application_id_pid_mapping_: ApplicationIdPidMapping<...>&
  +ProxyServiceDataControlLocalView(service_data_control: ServiceDataControl&)
  ..
  <u>Notes:</u>
  Created once per Proxy at construction. Builds ConsumerEventControlLocalView\nentries for every event in ServiceDataControl, avoiding per-call OffsetPtr\nindirection when accessing the control map at runtime.
}

class "<<SharedMemory>>\nlola::SkeletonDataControl" {
  +event_data_control_: std::map<ElementFqId, EventDataControl>
  +skeleton_pid_: pid_t
  +SkeletonDataControl(proxy: score::memory::shared::MemoryResourceProxy* const)
}

class "<<SharedMemory>>\nlola::EventDataControl" {
  +state_slots_: DynamicArray<ControlSlotType, PolymorphicOffsetPtrAllocator<ControlSlotType>>
  +EventDataControl(max_slots: SlotIndexType, resource: ManagedMemoryResource&)
  ..
  <u>Notes:</u>
  Pure data class stored in shared memory. Holds the atomic slot-state array.\nAll behaviour (AllocateNextSlot, EventReady, ReferenceNextEvent, etc.) has been\nmoved to ProviderEventDataControlLocalView / ConsumerEventDataControlLocalView\nto avoid OffsetPtr overhead in the hot path.\nExists at least once per provided Event. For ASIL-B providers with both ASIL-B\nand QM consumers it exists twice (one per quality level in separate shm objects).
}

class "<<SharedMemory>>\nlola::EventSlotStatus" {
  +EventSlotStatus(init_val: const value_type)
  +IsInvalid(): bool
  +IsInWriting(): bool
  +MarkInWriting(): void
  +MarkInvalid(): void
  +GetReferenceCount(): SubscriberCount
  +GetTimeStamp(): EventTimeStamp
  +SetTimeStamp(EventTimeStamp)
  +SetReferenceCount(SubscriberCount)
  +IsUsed(): bool
  +IsTimeStampBetween(EventTimeStamp min, EventTimeStamp max): bool
}

class EventDataControlComposite<memory::shared::AtomicIndirectorType> {
  -asil_qm_control_local_: ProviderEventDataControlLocalView<>&
  -asil_b_control_local_: ProviderEventDataControlLocalView<>*
  +EventDataControlComposite(asil_qm_control_local: ProviderEventDataControlLocalView<>&)
  +EventDataControlComposite(asil_qm_control_local: ProviderEventDataControlLocalView<>&, asil_b_control_local: ProviderEventDataControlLocalView<>*)
  +AllocateNextSlot(): AllocationResult
  +EventReady(slot_index: SlotIndexType, time_stamp: EventSlotStatus::EventTimeStamp): void
  +Discard(slot_index: SlotIndexType): void
  +IsQmControlDisconnected(): bool
  +GetQmEventDataControlLocal(): ProviderEventDataControlLocalView<>&
  +GetAsilBEventDataControlLocal(): ProviderEventDataControlLocalView<>*
}

enum SubscriptionState {
  SUBSCRIBED
  NOT_SUBSCRIBED
  SUBSCRIPTION_PENDING
}

SkeletonEventBindingBase <|-- SkeletonEventBinding
SkeletonEventBinding <|-- lola::SkeletonEvent
ProxyEventBindingBase <|-- ProxyEventBinding
ProxyEventBinding <|-- lola::ProxyEvent
lola::Skeleton *-- SkeletonDataStorage : "1..1"
lola::Skeleton *-- "<<SharedMemory>>\nlola::SkeletonDataControl" : "1..2"
"<<SharedMemory>>\nlola::SkeletonDataControl" *-- "<<SharedMemory>>\nlola::EventDataControl" : "0..n"
lola::SkeletonEvent o-- "EventDataStorage"
lola::SkeletonEvent *-- lola::SkeletonEventCommon
"<<SharedMemory>>\nlola::EventDataControl" ..> "<<SharedMemory>>\nlola::EventSlotStatus"
SampleAllocateePtr o-- lola::SampleAllocateePtr
SamplePtr o-- lola::SamplePtr
lola::ProxyEvent *-- lola::ProxyEventCommon
lola::ProxyEventCommon *-- lola::SubscriptionStateMachine
ProxyEventBindingBase o-- SubscriptionState
lola::SampleAllocateePtr *-- EventDataControlComposite
lola::Skeleton ..> lola::ShmPathBuilder : uses
lola::SubscriptionStateMachine ..> lola::SlotCollector : <<creates>>
SkeletonEventBinding ..> SampleAllocateePtr
lola::ProxyEvent ..> lola::SamplePtr
SkeletonDataStorage *-- "EventDataStorage" : "0..n"
ProxyEventBinding ..> SamplePtr
lola::SkeletonEvent ..> lola::SampleAllocateePtr

' Local view relationships
lola::SkeletonEventCommon *-- "0..2" ProviderEventDataControlLocalView
lola::SkeletonEventCommon *-- "0..2" ConsumerEventDataControlLocalView
lola::SkeletonEventCommon *-- EventDataControlComposite
EventDataControlComposite o-- "1..2" ProviderEventDataControlLocalView
ProviderEventDataControlLocalView ..> "<<SharedMemory>>\nlola::EventDataControl" : accesses via span
ConsumerEventDataControlLocalView ..> "<<SharedMemory>>\nlola::EventDataControl" : accesses via span
lola::ProxyEventCommon o-- ConsumerEventControlLocalView : event_control_local_
ConsumerEventControlLocalView *-- ConsumerEventDataControlLocalView
ConsumerEventControlLocalView ..> "<<SharedMemory>>\nlola::EventSubscriptionControl" : subscription_control ref
ConsumerEventControlLocalView ..> "<<SharedMemory>>\nlola::TransactionLogSet" : transaction_log_set ref
lola::SlotCollector o-- ConsumerEventDataControlLocalView
lola::SampleAllocateePtr o-- ConsumerEventDataControlLocalView
lola::SamplePtr *-- lola::SlotDecrementer
lola::SlotDecrementer o-- ConsumerEventDataControlLocalView
lola::Proxy *-- ProxyServiceDataControlLocalView : service_data_control_local_
ProxyServiceDataControlLocalView *-- "1..n" ConsumerEventControlLocalView

@enduml
